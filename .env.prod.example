# Database Configuration
DB_USER=losev_admin
DB_PASSWORD=your_strong_password
DB_NAME=losev_portal_prod

# Redis Configuration
REDIS_PASSWORD=another_strong_password

# Backend Configuration
JWT_SECRET=generate_a_long_random_string
CORS_ORIGINS=https://portal.losev.org.tr

# Mobile (Web) Configuration
# This is used at build time for the web version
EXPO_PUBLIC_API_URL=https://portal.losev.org.tr/api/v1

# Sentry (Optional)
SENTRY_DSN=your_sentry_dsn
