# Stage 1: Build
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Build the web application
# For Expo 54, use 'npx expo export --platform web'
RUN npx expo export --platform web

# Stage 2: Production
FROM nginx:stable-alpine

# Copy built application from builder to Nginx
# Expo 51+ exports web files into the 'dist' folder
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy Nginx configuration (optional, for SPA support)
# COPY nginx.conf /etc/nginx/conf.d/default.conf

# Expose port 80
EXPOSE 80

# Start Nginx
CMD ["nginx", "-g", "daemon off;"]
